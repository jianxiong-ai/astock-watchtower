DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/astock_watchtower
REDIS_URL=redis://redis:6379/0
API_CORS_ORIGINS=http://localhost:3000

# Browser-visible API base URL. For Docker on the same machine keep localhost:8000.
# If deploying to a server/domain, set this to the public API URL before building the web image.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional Feishu signing secret for custom bot webhook.
FEISHU_DEFAULT_SECRET=
# Feishu message mode: card or text.
FEISHU_MESSAGE_MODE=card

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0

# Optional comma-separated YYYY-MM-DD dates. Used as a local override/fallback on top of official SSE/SZSE calendar providers.
A_SHARE_HOLIDAYS=

# Official announcement lookback for subscription trigger checks.
ANNOUNCEMENT_LOOKBACK_DAYS=30

# Longer evidence window for manual analysis/reporting. This does not create old-announcement push triggers.
ANALYSIS_ANNOUNCEMENT_LOOKBACK_DAYS=180

# PDF extraction limits. Increase only if you accept slower announcement sync.
PDF_EXTRACT_MAX_PAGES=8
PDF_TEXT_MAX_CHARS=20000
PDF_TABLE_MAX_PAGES=12
PDF_TABLE_MAX_TABLES=12
PDF_TABLE_MAX_CHARS=15000

# Optional custom industry provider CSV directory mounted into the API container.
# Example: data/industry_providers/copper_chain.csv -> /data/industry_providers/copper_chain.csv
INDUSTRY_PROVIDER_DATA_DIR=/data/industry_providers
